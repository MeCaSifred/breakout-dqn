# ══════════════════════════════════════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ══════════════════════════════════════════════════════════════════════════════
# Entorno virtual — no se sube al repo (cada persona crea el suyo)
# ══════════════════════════════════════════════════════════════════════════════
venv_breakout/
venv/
.venv/
env/

# ══════════════════════════════════════════════════════════════════════════════
# Checkpoints del modelo entrenado — muy pesados (~40 MB cada uno)
# ══════════════════════════════════════════════════════════════════════════════
checkpoints/
*.pth
*.pt

# ══════════════════════════════════════════════════════════════════════════════
# Archivos del sistema operativo
# ══════════════════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini

# ══════════════════════════════════════════════════════════════════════════════
# IDEs y editores
# ══════════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo

# ══════════════════════════════════════════════════════════════════════════════
# Archivos temporales de Python
# ══════════════════════════════════════════════════════════════════════════════
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# ══════════════════════════════════════════════════════════════════════════════
# Logs y archivos de entrenamiento secundarios (opcional)
# ══════════════════════════════════════════════════════════════════════════════
*.log
